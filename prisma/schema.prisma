// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id            String         @id @default(uuid(7)) @db.Uuid
  name          String
  slug          String         @unique
  city          String
  location      String
  startDateTime DateTime // First day of event and event's start time (e.g., 2025-07-10 10:30:00)
  endDateTime   DateTime // Last day of event and event's end time (e.g., 2025-07-10 17:30:00)
  organizerName String
  venueName     String
  imageUrl      String
  description   String
  bookings      EventBooking[]
  updatedAt     DateTime       @updatedAt
}

model EventBooking {
  id                String        @id @default(uuid(7)) @db.Uuid
  attendeeFirstName String
  attendeeLastName  String
  email             String
  phone             String?
  bookedDateTime    DateTime // When attendee plans to visit
  totalTickets      Int           @default(1)
  bookingStatus     BookingStatus @default(PENDING)
  eventId           String        @db.Uuid
  event             Event         @relation(fields: [eventId], references: [id])
  updatedAt         DateTime      @updatedAt
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELED
}
